<?xml version="1.0" encoding="UTF-8"?>
<addon id="plugin.video.espatv" name="EspaTV" version="1.0.2" provider-name="RubénSDFA1labernt">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
    <import addon="script.module.requests"/>
    <import addon="inputstream.adaptive" optional="true"/>
  </requires>
  <extension point="xbmc.python.pluginsource" library="default.py">
    <provides>video</provides>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="es">TV, vídeos, radio y podcast en castellano — todo en uno</summary>
    <description lang="es">Addon todo-en-uno para contenido en castellano. TDT, RTVE a la carta, búsqueda en Dailymotion y YouTube, catálogo de vídeos en castellano, radio, podcast, reproduce vídeos desde enlaces y mucho más.</description>
    <platform>all</platform>
    <license>GPL-2.0-or-later</license>
    <website>https://github.com/espakodi</website>
    <source>https://github.com/espakodi</source>
    <assets>
      <icon>icon.png</icon>
      <fanart>fanart.jpg</fanart>
    </assets>
  </extension>
</addon>